# ═══════════════════════════════════════════════════
# Mantle AI Swarm — Environment Configuration
# ═══════════════════════════════════════════════════

# D1: Ouroboros LLM Brain (required)
OPENROUTER_API_KEY=sk-or-your-key-here

# D5: Mantle Chain (optional — enables live tx broadcast)
# Without this key, the engine runs in DRY-RUN mode (calldata only).
# The wallet must be the controller of Agent #1 NFT on ERC8004Registry.
MANTLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Override defaults (optional)
# MANTLE_RPC_URL=https://rpc.mantle.xyz
# CYCLE_INTERVAL_SECS=60
# RUST_LOG=swarm_engine=info,ouroboros_brain=info
